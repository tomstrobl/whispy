%% whispy architecture — paste into https://mermaid.live to export PNG/SVG
flowchart TB
    subgraph DRV["Driver — examples/ notebooks"]
        NB["building_block_*  ·  full_experiment_*<br/>(consent → test → thanks)"]
    end

    subgraph CFG["Configuration (YAML) — read_config() / load_design()"]
        direction TB
        C1["design.yml — shared theme"]
        C2["drag_and_drop_mushra.yml · staircase_n_afc.yml · abx.yml<br/>self-contained per experiment:<br/>SoundDevice (id→file) · ui · scales/test · experiment"]
        C5["questionnaires/ — consent · general"]
        C6["thanks.yml · participant_id.yml"]
    end

    subgraph ORCH["Orchestration"]
        SCH["ExperimentScheduler<br/>randomizes → yields screen dicts"]
        STC["Staircase<br/>adaptive up/down (GUI-free)"]
    end

    subgraph UI["UI layer (PyQt6) — _BaseUIWindow"]
        MU["DragAndDropMUSHRA"]
        NA["NAFC"]
        AB["ABX"]
        QU["Questionnaire"]
        IN["InfoWindow"]
        PI["ParticipantID (legacy)"]
    end

    subgraph AUD["Audio interface"]
        SH["StimuliHandler (ABC)"]
        SD["SoundDevice → pyfar · sounddevice"]
    end

    subgraph RES["Results"]
        GR["get_results() → pandas DataFrame"]
        SR["save_results() → examples/results/*.csv"]
    end

    NB --> ORCH
    SCH -->|screen dict| UI
    STC -->|drives trials| NA
    UI -->|"play(stimulus)"| AUD
    SH --> SD
    UI -->|rows / trial| RES
    GR --> SR

    CFG -. feeds every layer .-> ORCH
    CFG -.-> UI
    CFG -.-> AUD

    classDef cfg fill:#E9C46A,stroke:#C9A227,color:#5a4708;
    classDef orch fill:#E76F51,stroke:#c0492f,color:#fff;
    classDef ui fill:#2A9D8F,stroke:#1f6f64,color:#fff;
    classDef aud fill:#264653,stroke:#16303a,color:#fff;
    classDef res fill:#8AB17D,stroke:#5e8a4f,color:#22331b;
    classDef drv fill:#2D3142,stroke:#1b1d28,color:#fff;
    class C1,C2,C5,C6 cfg;
    class SCH,STC orch;
    class MU,NA,AB,QU,IN,PI ui;
    class SH,SD aud;
    class GR,SR res;
    class NB drv;
